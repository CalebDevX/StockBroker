# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/stockbroker_ng

# ── Auth ────────────────────────────────────────────────────────────────────
# Random 48-byte base64 string. Generate with: openssl rand -base64 48
JWT_SECRET=31uTOardO/UDZxclPh4nPuGoXfdn05DWzLc65L7dPxZQLMJrw5DQlX2GqBMpDYES

# ── Broker Config ───────────────────────────────────────────────────────────
# Your SEC-assigned broker code (4 digits)
BROKER_CODE=0001

# ── API Server ──────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
TRADING_MODE=demo
FIX_HOST=
FIX_PORT=4849
FIX_SENDER_COMP_ID=
FIX_TARGET_COMP_ID=NGXATS
FIX_PASSWORD=
CSCS_API_URL=
CSCS_API_KEY=
CSCS_BROKER_CODE=
CSCS_WEBHOOK_SECRET=
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@stockbroker.ng
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# Brevo SMTP works with SMTP provider. Set SMTP_USER and SMTP_PASS from Brevo SMTP credentials.
APP_NAME=StockBroker NG
APP_URL=https://app.stockbroker.ng
SUPPORT_EMAIL=support@stockbroker.ng

# Optional fallback branding values when admin settings are not yet configured.
# Actual platform name and URL are stored in the DB keys app_name and app_url.

# ── Client Portal ───────────────────────────────────────────────────────────
# Port for the Vite dev server / static file server
# PORT=3000
# BASE_PATH=/   (leave as / unless hosting at a sub-path)

# ── Seed Script (optional overrides) ────────────────────────────────────────
# ADMIN_EMAIL=admin@yourfirm.com
