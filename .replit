modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "8080"
NODE_ENV = "development"
TRADING_MODE = "demo"
BROKER_CODE = "0001"
JWT_SECRET = "31uTOardO/UDZxclPh4nPuGoXfdn05DWzLc65L7dPxZQLMJrw5DQlX2GqBMpDYES"
APP_NAME = "StockBroker NG"
APP_URL = "http://localhost:3000"
SUPPORT_EMAIL = "support@stockbroker.ng"
EMAIL_PROVIDER = "smtp"
EMAIL_FROM = "noreply@stockbroker.ng"
SMTP_HOST = "smtp-relay.brevo.com"
SMTP_PORT = "587"
SMTP_SECURE = "false"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/client-portal && PORT=5000 pnpm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && pnpm run build && pnpm run start"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=5000 node --enable-source-maps artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/db run push && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/client-portal run build"]
